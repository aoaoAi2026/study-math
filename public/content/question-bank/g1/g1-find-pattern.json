    {
      "id": "g1-fp-16",
      "type": "choice",
      "difficulty": 5,
      "difficultyLabel": "竞赛",
      "stem": "把 1~100 的数按顺序排成一行：1 2 3 4 ... 9 10 11 12 ...。数字 42 是第几个数字（一个一位数算1个数字，一个两位数算2个数字）？",
      "options": [
        "第 42 个",
        "第 72 个",
        "第 75 个",
        "第 84 个"
      ],
      "answer": "2",
      "acceptableAnswers": [
        "第75个"
      ],
      "solution": [
        "1到9都是一位数，共 9 个数 = 9 个数字。",
        "10到42都是两位数，有 42-10+1 = 33 个数。",
        "33 个两位数 = 33×2 = 66 个数字。",
        "总共：9 + 66 = 75 个数字。",
        "所以数字 42 的\"4\"是第 75 个数字。"
      ],
      "hints": [
        "一位数有9个",
        "两位数从10开始",
        "到42有多少个两位数？",
        "42-10+1=33个两位数",
        "33×2=66",
        "9+66=75"
      ],
      "commonMistakes": [
        {
          "mistake": "选 第42个或84个",
          "reason": "不知道两位数占两个位置",
          "correction": "两位数每个占2个数字",
          "errorLayer": "L4"
        }
      ],
      "knowledgePoints": [
        "页码问题",
        "数字计数"
      ],
      "estimatedTime": 200,
      "irtParams": {
        "a": 1.1,
        "b": 1.8,
        "c": 0.25
      },
      "tags": [
        "页码问题",
        "竞赛"
      ],
      "image": "",
      "source": {
